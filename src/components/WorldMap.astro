---

<div id="world-map" class="world-map-container"></div>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark';

  const darkStyle = 'https://basemaps.cartocdn.com/gl/dark-matter-nolabels-gl-style/style.json';
  const lightStyle = 'https://basemaps.cartocdn.com/gl/positron-nolabels-gl-style/style.json';

  function applyThemeColors(map: maplibregl.Map) {
    const dark = isDark();

    // Restyle background
    const bgLayer = map.getLayer('background');
    if (bgLayer) {
      map.setPaintProperty('background', 'background-color', dark ? '#0e1a14' : '#ece6dd');
    }

    // Restyle water
    for (const id of ['water', 'water_name']) {
      if (map.getLayer(id)) {
        map.setPaintProperty(id, 'fill-color', dark ? '#0a1410' : '#d4cbbf');
      }
    }

    // Restyle landcover / landuse
    for (const id of ['landcover', 'landuse']) {
      if (map.getLayer(id)) {
        map.setPaintProperty(id, 'fill-color', dark ? '#1b4332' : '#e4dbd0');
      }
    }

    // Restyle land and earth layers
    const landLayers = map.getStyle().layers.filter(
      (l: maplibregl.LayerSpecification) =>
        l.id.includes('land') || l.id.includes('earth') || l.id.includes('park')
    );
    for (const layer of landLayers) {
      if (layer.type === 'fill') {
        const color = layer.id.includes('park')
          ? (dark ? '#163b28' : '#d8cebc')
          : (dark ? '#12261c' : '#e4dbd0');
        map.setPaintProperty(layer.id, 'fill-color', color);
      }
    }

    // Restyle boundaries
    const boundaryLayers = map.getStyle().layers.filter(
      (l: maplibregl.LayerSpecification) => l.id.includes('boundary') || l.id.includes('admin')
    );
    for (const layer of boundaryLayers) {
      if (layer.type === 'line') {
        map.setPaintProperty(layer.id, 'line-color', dark ? '#52b788' : '#b5461a');
        map.setPaintProperty(layer.id, 'line-opacity', dark ? 0.4 : 0.35);
      }
    }

    // Restyle buildings
    const buildingLayers = map.getStyle().layers.filter(
      (l: maplibregl.LayerSpecification) => l.id.includes('building')
    );
    for (const layer of buildingLayers) {
      if (layer.type === 'fill') {
        map.setPaintProperty(layer.id, 'fill-color', dark ? '#1b4332' : '#d4cbbf');
      }
    }
  }

  const map = new maplibregl.Map({
    container: 'world-map',
    style: isDark() ? darkStyle : lightStyle,
    center: [0, 20],
    zoom: 1.5,
    minZoom: 1.5,
    maxZoom: 6,
    attributionControl: false,
    scrollZoom: false,
  });

  map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

  map.on('style.load', () => applyThemeColors(map));

  // Watch for theme changes
  const observer = new MutationObserver(() => {
    map.setStyle(isDark() ? darkStyle : lightStyle);
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>

<style>
  .world-map-container {
    height: 350px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    box-shadow: var(--glass-shadow);
    margin-bottom: 2rem;
    overflow: hidden;
    position: relative;
  }

  .world-map-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
    pointer-events: none;
    z-index: 1;
  }

  :root[data-theme='dark'] .world-map-container::before {
    background: linear-gradient(90deg, transparent, rgba(82, 183, 136, 0.2), transparent);
  }

  .world-map-container :global(.maplibregl-ctrl-group) {
    border: 1px solid var(--glass-border) !important;
    border-radius: 8px !important;
    overflow: hidden;
    box-shadow: var(--glass-shadow) !important;
    background: var(--glass-bg) !important;
    backdrop-filter: blur(12px);
  }

  .world-map-container :global(.maplibregl-ctrl-group button) {
    background: transparent !important;
    color: var(--sl-color-text) !important;
    border-color: var(--glass-border) !important;
  }

  .world-map-container :global(.maplibregl-ctrl-group button:hover) {
    background: var(--glass-bg-hover) !important;
  }

  .world-map-container :global(.maplibregl-ctrl-group button span) {
    filter: var(--sl-color-text);
  }

  :root[data-theme='dark'] .world-map-container :global(.maplibregl-ctrl-group button span) {
    filter: invert(1);
  }
</style>

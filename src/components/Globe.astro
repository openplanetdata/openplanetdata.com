---
---

<div class="globe-hero">
  <canvas id="globe-canvas"></canvas>
</div>

<script>
  import * as THREE from 'three';
  import { mesh } from 'topojson-client';
  import type { Topology } from 'topojson-specification';
  import GeoJsonGeometry from 'three-geojson-geometry';

  const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
  const container = canvas.parentElement!;
  const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark';

  // Scene
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(32, container.clientWidth / container.clientHeight, 0.1, 100);
  camera.position.set(0.3, 0.4, 4.0);
  camera.lookAt(0, 0, 0);

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.setClearColor(0x000000, 0);

  function resize() {
    const w = container.clientWidth;
    const h = container.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  }
  window.addEventListener('resize', resize);

  const TILT = 23.4 * Math.PI / 180;
  const globeGroup = new THREE.Group();
  globeGroup.rotation.x = TILT;
  scene.add(globeGroup);

  function accentColor(): THREE.Color {
    return isDark() ? new THREE.Color(0x52b788) : new THREE.Color(0xe07a4a);
  }

  // ── Solid sphere with shading ──
  const globeMat = new THREE.ShaderMaterial({
    uniforms: {
      uColor: { value: new THREE.Color(0x52b788) },
      uDark: { value: 1.0 },
    },
    vertexShader: `
      varying vec3 vNormal;
      varying vec3 vViewDir;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vec4 mv = modelViewMatrix * vec4(position, 1.0);
        vViewDir = normalize(-mv.xyz);
        gl_Position = projectionMatrix * mv;
      }
    `,
    fragmentShader: `
      uniform vec3 uColor;
      uniform float uDark;
      varying vec3 vNormal;
      varying vec3 vViewDir;
      void main() {
        float fresnel = 1.0 - max(dot(vViewDir, vNormal), 0.0);
        fresnel = pow(fresnel, 3.0);
        // Directional light
        float light = max(dot(vNormal, normalize(vec3(0.5, 0.8, 1.0))), 0.0);
        // Dark: deep forest. Light: warm sand matching page bg.
        vec3 baseD = vec3(0.035, 0.065, 0.05);
        vec3 rimD = uColor * 0.25;
        vec3 baseL = vec3(0.88, 0.86, 0.83);
        vec3 rimL = vec3(0.75, 0.73, 0.70);
        vec3 base = mix(baseL, baseD, uDark);
        vec3 rim = mix(rimL, rimD, uDark);
        vec3 col = mix(base, rim, fresnel);
        col += light * mix(0.05, 0.04, uDark);
        gl_FragColor = vec4(col, 1.0);
      }
    `,
  });
  globeGroup.add(new THREE.Mesh(new THREE.SphereGeometry(1, 80, 80), globeMat));

  // Atmosphere rim
  const atmosMat = new THREE.ShaderMaterial({
    transparent: true,
    depthWrite: false,
    side: THREE.BackSide,
    uniforms: {
      uColor: { value: new THREE.Color(0x52b788) },
      uDark: { value: 1.0 },
    },
    vertexShader: `
      varying vec3 vNormal;
      varying vec3 vViewDir;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vec4 mv = modelViewMatrix * vec4(position, 1.0);
        vViewDir = normalize(-mv.xyz);
        gl_Position = projectionMatrix * mv;
      }
    `,
    fragmentShader: `
      uniform vec3 uColor;
      uniform float uDark;
      varying vec3 vNormal;
      varying vec3 vViewDir;
      void main() {
        float rim = pow(max(dot(vViewDir, vNormal), 0.0), 1.8);
        gl_FragColor = vec4(uColor, rim * mix(0.18, 0.15, uDark));
      }
    `,
  });
  globeGroup.add(new THREE.Mesh(new THREE.SphereGeometry(1.05, 64, 64), atmosMat));

  // ── Subtle lat/lon grid ──
  function buildGrid(color: THREE.Color): THREE.LineSegments {
    const v: number[] = [];
    const s = 3 * Math.PI / 180;
    const R = 1.001;
    for (let lat = -60; lat <= 60; lat += 30) {
      const p = (90 - lat) * Math.PI / 180;
      for (let a = 0; a < 2 * Math.PI; a += s) {
        const b = a + s;
        v.push(R * Math.sin(p) * Math.cos(a), R * Math.cos(p), R * Math.sin(p) * Math.sin(a));
        v.push(R * Math.sin(p) * Math.cos(b), R * Math.cos(p), R * Math.sin(p) * Math.sin(b));
      }
    }
    for (let lon = 0; lon < 360; lon += 30) {
      const th = lon * Math.PI / 180;
      for (let a = -Math.PI / 2; a < Math.PI / 2; a += s) {
        const p1 = Math.PI / 2 - a, p2 = Math.PI / 2 - (a + s);
        v.push(R * Math.sin(p1) * Math.cos(th), R * Math.cos(p1), R * Math.sin(p1) * Math.sin(th));
        v.push(R * Math.sin(p2) * Math.cos(th), R * Math.cos(p2), R * Math.sin(p2) * Math.sin(th));
      }
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.Float32BufferAttribute(v, 3));
    return new THREE.LineSegments(geo, new THREE.LineBasicMaterial({ color, transparent: true, opacity: 0.06 }));
  }
  const grid = buildGrid(accentColor());
  globeGroup.add(grid);

  // ── World data: continents + animated boundaries ──
  let coastObj: THREE.LineSegments | null = null;
  let borderObj: THREE.LineSegments | null = null;

  const GLOBE_R = 1; // must match sphere radius

  const coastMat = new THREE.LineBasicMaterial({ color: accentColor(), transparent: true, opacity: 0.35 });

  const borderMat = new THREE.ShaderMaterial({
    transparent: true,
    uniforms: {
      uTime: { value: 0 },
      uColor: { value: accentColor() },
      uDark: { value: 1.0 },
    },
    vertexShader: `
      varying vec3 vWorldPos;
      void main() {
        vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform float uTime;
      uniform vec3 uColor;
      uniform float uDark;
      varying vec3 vWorldPos;

      void main() {
        float y = vWorldPos.y;
        float x = vWorldPos.x;
        float z = vWorldPos.z;
        float angle = atan(z, x);

        float t = uTime * 0.001;
        float s1 = sin(y * 4.0 + angle * 2.0 + t * 1.5);
        float sparks = pow(max(s1, 0.0), 200.0);

        float baseAlpha = 0.25;
        float sparkAlpha = mix(0.8, 1.5, uDark);
        float alpha = baseAlpha + sparks * sparkAlpha;

        // Dark: sparks glow white. Light: sparks go darker.
        vec3 sparkColorDark = vec3(1.0);
        vec3 sparkColorLight = mix(uColor, vec3(1.0, 0.6, 0.2), 0.3);
        vec3 sparkTarget = mix(sparkColorLight, sparkColorDark, uDark);
        vec3 col = mix(uColor, sparkTarget, min(sparks * 0.8, 0.7));

        gl_FragColor = vec4(col, min(alpha, 1.0));
      }
    `,
  });

  async function loadWorld() {
    try {
      const resp = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json');
      const world = await resp.json() as Topology;

      // Continent borders (coastlines) — animated
      const landGeo = mesh(world, world.objects.land);
      const coastGeometry = new GeoJsonGeometry(landGeo, GLOBE_R);
      coastObj = new THREE.LineSegments(coastGeometry, borderMat);
      globeGroup.add(coastObj);
    } catch (e) {
      console.warn('Globe: failed to load world data', e);
    }
  }

  loadWorld();

  // ── Theme sync ──
  function syncTheme() {
    const dark = isDark();
    const c = accentColor();
    const df = dark ? 1.0 : 0.0;

    globeMat.uniforms.uColor.value.copy(c);
    globeMat.uniforms.uDark.value = df;
    atmosMat.uniforms.uColor.value.copy(c);
    atmosMat.uniforms.uDark.value = df;

    (grid.material as THREE.LineBasicMaterial).color.copy(c);
    (grid.material as THREE.LineBasicMaterial).opacity = dark ? 0.06 : 0.1;

    coastMat.color.copy(c);
    coastMat.opacity = dark ? 0.3 : 0.45;

    borderMat.uniforms.uColor.value.copy(c);
    borderMat.uniforms.uDark.value = df;
  }

  const observer = new MutationObserver(() => syncTheme());
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  // ── Mouse/touch drag ──
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let rotYOffset = 0;
  let rotXOffset = 0;
  let rotYStart = 0;
  let rotXStart = 0;
  let lastDragTime = 0;
  let velocityX = 0;
  let velocityY = 0;

  canvas.style.cursor = 'grab';

  canvas.addEventListener('pointerdown', (e) => {
    isDragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    rotYStart = rotYOffset;
    rotXStart = rotXOffset;
    velocityX = 0;
    velocityY = 0;
    lastDragTime = performance.now();
    canvas.style.cursor = 'grabbing';
    canvas.setPointerCapture(e.pointerId);
  });

  canvas.addEventListener('pointermove', (e) => {
    if (!isDragging) return;
    const now = performance.now();
    const dt = now - lastDragTime;
    const dx = e.clientX - dragStartX;
    const dy = e.clientY - dragStartY;
    rotYOffset = rotYStart + dx * 0.005;
    rotXOffset = rotXStart + dy * 0.003;
    // Clamp vertical rotation
    rotXOffset = Math.max(-0.5, Math.min(0.5, rotXOffset));
    if (dt > 0) {
      velocityX = (dx * 0.005 - (rotYOffset - rotYStart - dx * 0.005)) / dt * 16;
      velocityY = 0;
      velocityX = (e.movementX * 0.005);
    }
    lastDragTime = now;
  });

  canvas.addEventListener('pointerup', () => {
    isDragging = false;
    canvas.style.cursor = 'grab';
  });

  canvas.addEventListener('pointerleave', () => {
    if (isDragging) {
      isDragging = false;
      canvas.style.cursor = 'grab';
    }
  });

  // ── Animation loop ──
  let started = false;
  const autoSpeed = 0.00008;

  function frame(t: number) {
    if (!started) {
      started = true;
      syncTheme();
    }

    // Animate boundary pulse
    borderMat.uniforms.uTime.value = t;

    // Inertia decay when not dragging
    if (!isDragging) {
      velocityX *= 0.95;
      rotYOffset += velocityX;
    }

    // Auto rotation + manual offset
    globeGroup.rotation.y = t * autoSpeed + rotYOffset;
    globeGroup.rotation.x = TILT + rotXOffset;

    renderer.render(scene, camera);
    requestAnimationFrame(frame);
  }

  requestAnimationFrame(frame);
</script>

<style>
  .globe-hero {
    position: relative;
    width: 100%;
    height: 280px;
    margin: -0.5rem 0 0.25rem;
    overflow: hidden;
  }

  #globe-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

</style>

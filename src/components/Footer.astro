---
import LastUpdated from '@astrojs/starlight/components/LastUpdated.astro';
import Pagination from '@astrojs/starlight/components/Pagination.astro';
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<LastUpdated />
	</div>

	<div class="feedback-section">
		<span class="feedback-label">Was this page helpful?</span>
		<div class="feedback-buttons">
			<button type="button" class="thumb-btn" aria-label="Yes, this was helpful" data-feedback="yes">
				<svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
					<path fill="none" d="M0 0h24v24H0V0zm0 0h24v24H0V0z"></path>
					<path d="M9 21h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.58 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2zM9 9l4.34-4.34L12 10h9v2l-3 7H9V9zM1 9h4v12H1z"></path>
				</svg>
				<span>Yes</span>
			</button>
			<button type="button" class="thumb-btn" aria-label="No, this was not helpful" data-feedback="no">
				<svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
					<path fill="none" d="M0 0h24v24H0V0zm0 0h24v24H0V0z"></path>
					<path d="M15 3H6c-.83 0-1.54.5-1.84 1.22l-3.02 7.05c-.09.23-.14.47-.14.73v2c0 1.1.9 2 2 2h6.31l-.95 4.57-.03.32c0 .41.17.79.44 1.06L9.83 23l6.59-6.59c.36-.36.58-.86.58-1.41V5c0-1.1-.9-2-2-2zm0 12-4.34 4.34L12 14H3v-2l3-7h9v10zm4-12h4v12h-4z"></path>
				</svg>
				<span>No</span>
			</button>
		</div>
	</div>

	<Pagination />

	<div class="copyright">
		&copy; {new Date().getFullYear()} OpenPlanetData &mdash; Made with &#10084; by <a href="https://github.com/laurentpellegrino" target="_blank" rel="noopener">Laurent Pellegrino</a> and <a href="https://github.com/openplanetdata" target="_blank" rel="noopener">contributors</a>.
	</div>
</footer>

<script>
	document.querySelectorAll('.thumb-btn:not([data-initialized])').forEach(btn => {
		btn.setAttribute('data-initialized', 'true');
		btn.addEventListener('click', (e) => {
			const button = e.currentTarget as HTMLButtonElement;
			button.parentElement?.querySelectorAll('.thumb-btn').forEach(b => {
				b.classList.remove('active');
			});
			button.classList.add('active');
		});
	});

	// Make sidebar group labels clickable to their overview pages
	const groupLinks: Record<string, string> = {
		'Boundaries': '/datasets/boundaries/',
	};

	document.querySelectorAll('.sidebar-content summary .group-label .large').forEach(label => {
		const text = label.textContent?.trim() || '';
		const href = groupLinks[text];
		if (!href) return;
		const groupLabel = label.closest('.group-label');
		if (!groupLabel || groupLabel.hasAttribute('data-linked')) return;
		groupLabel.setAttribute('data-linked', 'true');
		(groupLabel as HTMLElement).style.cursor = 'pointer';
		groupLabel.addEventListener('click', (e) => {
			e.preventDefault();
			e.stopPropagation();
			window.location.href = href;
		});
		// Apply active state when on the linked page
		if (window.location.pathname === href) {
			const summary = groupLabel.closest('summary');
			if (summary) {
				summary.setAttribute('aria-current', 'page');
			}
		}
	});
</script>

<style>
	footer {
		flex-direction: column;
		gap: 1.5rem;
	}

	.meta {
		gap: 0.75rem 3rem;
		justify-content: space-between;
		flex-wrap: wrap;
		margin-top: 3rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}

	.meta > :global(p:only-child) {
		margin-inline-start: auto;
	}

	.feedback-section {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.feedback-label {
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
	}

	.feedback-buttons {
		display: flex;
		gap: 0.5rem;
	}

	.thumb-btn {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.75rem;
		background: var(--glass-bg, rgba(255,255,255,0.45));
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--glass-border, rgba(255,255,255,0.5));
		border-radius: 50px;
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-sm);
		cursor: pointer;
		transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 2px 8px rgba(0,0,0,0.04);
	}

	.thumb-btn:hover {
		color: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
		box-shadow: 0 4px 12px rgba(45,106,79,0.1);
	}

	.thumb-btn.active {
		color: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
		background: var(--sl-color-accent-low);
		box-shadow: 0 4px 12px rgba(45,106,79,0.15);
	}

	.copyright {
		text-align: center;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		padding-top: 1rem;
	}

	.copyright a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
	}

	.copyright a:hover {
		color: var(--sl-color-accent);
	}
</style>
